# ── macOS / 에디터 ─────────────────────────────────────
.DS_Store
._*
.vscode/
.idea/
*.swp

# ── 비밀정보 / 환경변수 ────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Claude Code / loopy 로컬 런타임 ─────────────────────
# 소스(skills·agents 등)는 전부 레포 루트에 있고, .claude/ 아래엔 세션마다
# 새로 생기는 런타임 상태(.claude/loop/)만 쌓이므로 통째로 무시한다.
# 훗날 loop 상태를 커밋하려면 `git add -f`.
.claude/

# ── 언어 도구 산출물 ───────────────────────────────────
node_modules/
__pycache__/
.venv/
